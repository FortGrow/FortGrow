// FortGrow CRM — Schema do banco de dados (PostgreSQL)
// Multi-tenant: todos os dados de cliente são isolados por clientId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Usuários & RBAC ───────────────────────────────

enum Role {
  ADMIN
  FINANCEIRO
  COMERCIAL
  GESTOR
  SOCIAL_MEDIA
  DESIGNER
  TRAFEGO_PAGO
  CONSULTOR
  CLIENTE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CONSULTOR)
  avatarUrl    String?
  phone        String?
  active       Boolean  @default(true)
  twoFactor    Boolean  @default(false)
  // Módulos liberados para colaboradores (chaves de módulo, ex.: "crm", "financeiro")
  permissions  String[] @default([])
  /// Permissões granulares por módulo: { "crm": "ved", "financeiro": "v" } (v=ver, e=editar, d=excluir)
  permissionsMatrix Json @default("{}")
  /// Incrementado a cada mudança de permissões/senha — invalida tokens antigos imediatamente
  tokenVersion Int @default(0)
  /// Escopo de clientes do colaborador: TODOS | COMISSIONADOS (só os clientes onde recebe comissão)
  clientScope  String @default("TODOS")
  // Usuários CLIENTE pertencem a um cliente e só enxergam os dados dele
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  accountFor    Client[]       @relation("accountManager")
  eventsCreated Event[]        @relation("eventCreator")
  consultantFor Client[]       @relation("consultant")
  commissions   StaffCommission[]
  leads         Lead[]
  tasks         Task[]
  ticketMsgs    TicketMessage[]
  notifications Notification[]
  logs          ActivityLog[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime
}

// ─────────────────────────────── Clientes (tenants) ───────────────────────────────

enum ClientStatus {
  ATIVO
  PAUSADO
  INATIVO
  ONBOARDING
}

enum BillingType {
  FIXO
  COMISSAO
}

model Client {
  id             String       @id @default(cuid())
  companyName    String
  tradeName      String?
  logoUrl        String?
  cnpj           String?
  segment        String?
  city           String?
  state          String?
  website        String?
  instagram      String?
  email          String?
  phone          String?
  status         ClientStatus @default(ATIVO)
  plan           String?
  billingType    BillingType  @default(FIXO)
  monthlyValue   Decimal      @default(0) @db.Decimal(12, 2)
  /// Contratos por comissão: % que o cliente fatura sobre o volume vendido (ex.: 3%)
  commissionBase  Decimal     @default(0) @db.Decimal(6, 3)
  /// Contratos por comissão: % da FortGrow sobre a comissão do cliente (ex.: 10%)
  commissionShare Decimal     @default(0) @db.Decimal(6, 3)
  contractStart  DateTime?
  contractMonths Int?
  projectStatus  String?      @default("Em andamento")
  /// Dados do Cliente (área separada do dashboard): como a operação funciona
  operationType  String?
  notes          String?
  /// Lixeira: cliente arquivado (restaurável por 30 dias antes da exclusão definitiva)
  archivedAt     DateTime?

  /// Contas de anúncio vinculadas: { googleAdsId, metaAdsId, instagram, ga4PropertyId }
  adAccounts     Json         @default("{}")

  /// Base de cálculo do dashboard de Performance: % do bruto que vira receita
  /// base e % de comissão/margem sobre ela. 100/100 = receita real igual à bruta.
  perfConvPercent       Decimal @default(100) @db.Decimal(6, 3)
  perfCommissionPercent Decimal @default(100) @db.Decimal(6, 3)

  accountManagerId String?
  accountManager   User?   @relation("accountManager", fields: [accountManagerId], references: [id], onDelete: SetNull)
  consultantId     String?
  consultant       User?   @relation("consultant", fields: [consultantId], references: [id], onDelete: SetNull)

  users      User[]
  services   ClientService[]
  contracts  Contract[]
  projects   Project[]
  campaigns  Campaign[]
  invoices   Invoice[]
  subscriptions Subscription[]
  adCampaigns   AdCampaign[]
  events        Event[]
  expenses   Expense[]
  documents  Document[]
  tickets    Ticket[]
  metrics    MetricSnapshot[]
  goals      Goal[]
  leads      Lead[]
  contentPosts ContentPost[]
  staffCommissions StaffCommission[]
  performanceEntries PerformanceEntry[]
  instagramEntries   InstagramEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────── CRM Comercial ───────────────────────────────

enum LeadStage {
  LEAD
  CONTATO
  DIAGNOSTICO
  REUNIAO
  PROPOSTA
  NEGOCIACAO
  FECHADO
  PERDIDO
}

model Lead {
  id             String    @id @default(cuid())
  companyName    String
  contactName    String?
  email          String?
  phone          String?
  whatsapp       String?
  instagram      String?
  facebook       String?
  linkedin       String?
  website        String?
  source         String?
  segment        String?
  city           String?
  state          String?
  potential      String?   @default("Médio") // Baixo | Médio | Alto
  estimatedValue Decimal   @default(0) @db.Decimal(12, 2)
  notes          String?
  stage          LeadStage @default(LEAD)
  /// Data do primeiro contato com o lead (padrão unificado Prospecção/CRM)
  firstContactAt DateTime?
  /// Status de prospecção: NOVO | CONTATADO | EM_CONVERSA | QUALIFICADO
  prospectStatus String    @default("NOVO")
  position       Int       @default(0)
  ownerId        String?
  owner          User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  // Quando fechado, pode virar cliente
  clientId       String?
  client         Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  activities LeadActivity[]
  proposals  Proposal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String   @default("nota") // nota | ligacao | email | reuniao | whatsapp | mudanca_etapa
  content   String
  author    String?
  createdAt DateTime @default(now())
}

enum ProposalStatus {
  ABERTA
  ENVIADA
  ACEITA
  RECUSADA
}

model Proposal {
  id        String         @id @default(cuid())
  title     String
  leadId    String
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  value     Decimal        @default(0) @db.Decimal(12, 2)
  status    ProposalStatus @default(ABERTA)
  validUntil DateTime?
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// ─────────────────────────────── Serviços & Contratos ───────────────────────────────

model Service {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  basePrice   Decimal         @default(0) @db.Decimal(12, 2)
  active      Boolean         @default(true)
  clients     ClientService[]
  createdAt   DateTime        @default(now())
}

enum ServiceStatus {
  ATIVO
  PAUSADO
  CONCLUIDO
  ATRASADO
}

model ClientService {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status      ServiceStatus @default(ATIVO)
  startDate   DateTime?
  deadline    DateTime?
  responsible String?
  checklist   Json          @default("[]") // [{label, done}]
  createdAt   DateTime      @default(now())
}

enum ContractStatus {
  ATIVO
  ENCERRADO
  RENOVACAO
  CANCELADO
}

model Contract {
  id           String         @id @default(cuid())
  clientId     String
  client       Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title        String
  value        Decimal        @default(0) @db.Decimal(12, 2)
  startDate    DateTime
  endDate      DateTime?
  status       ContractStatus @default(ATIVO)
  fileUrl      String?
  autoRenew    Boolean        @default(false)
  createdAt    DateTime       @default(now())
}

// ─────────────────────────────── Projetos & Tarefas ───────────────────────────────

enum ProjectStatus {
  BACKLOG
  EM_ANDAMENTO
  REVISAO
  CONCLUIDO
  ATRASADO
}

enum Priority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model Project {
  id        String        @id @default(cuid())
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  status    ProjectStatus @default(BACKLOG)
  priority  Priority      @default(MEDIA)
  startDate DateTime?
  deadline  DateTime?
  progress  Int           @default(0)
  notes     String?
  tasks     Task[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum TaskStatus {
  A_FAZER
  EM_ANDAMENTO
  EM_REVISAO
  CONCLUIDA
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(A_FAZER)
  priority    Priority   @default(MEDIA)
  dueDate     DateTime?
  timeSpentMin Int       @default(0)
  /// Cor do cartão no quadro (azul | verde | roxo | laranja | rosa | vermelho | ciano | amarelo)
  color       String?
  checklist   Json       @default("[]")
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?      @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    Json       @default("[]") // [{author, content, at}]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ─────────────────────────────── Campanhas & Métricas ───────────────────────────────

enum Channel {
  GOOGLE_ADS
  META_ADS
  INSTAGRAM
  SEO
  LINKEDIN
  TIKTOK
  EMAIL
  OUTRO
}

model Campaign {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  channel    Channel
  active     Boolean  @default(true)
  budget     Decimal  @default(0) @db.Decimal(12, 2)
  objective  String?
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime @default(now())
}

/// Snapshot diário de métricas por canal — alimentado pelas integrações
/// (Google Ads, Meta Ads, Instagram, Search Console) ou lançado manualmente.
model MetricSnapshot {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channel     Channel
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  reach       Int      @default(0)
  engagement  Int      @default(0)
  followers   Int      @default(0)
  leads       Int      @default(0)
  conversions Int      @default(0)
  spend       Decimal  @default(0) @db.Decimal(12, 2)
  revenue     Decimal  @default(0) @db.Decimal(12, 2)
  // SEO
  organicTraffic Int   @default(0)
  avgPosition    Float @default(0)
  backlinks      Int   @default(0)
  authority      Int   @default(0)

  @@unique([clientId, channel, date])
  @@index([clientId, date])
}

model Goal {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  metric    String // leads | receita | conversoes | seguidores
  period    String // mensal | anual
  target    Decimal  @default(0) @db.Decimal(12, 2)
  year      Int
  month     Int?
}

// ─────────────────────────────── Financeiro ───────────────────────────────

enum InvoiceStatus {
  EM_ABERTO
  PAGO
  ATRASADO
  CANCELADO
}

enum PaymentMethod {
  PIX
  BOLETO
  CARTAO
  TRANSFERENCIA
}

model Invoice {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal       @db.Decimal(12, 2)
  dueDate     DateTime
  paidAt      DateTime?
  status      InvoiceStatus @default(EM_ABERTO)
  method      PaymentMethod?
  nfeUrl      String?
  /// Cobrança gerada por uma mensalidade (null = cobrança avulsa)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())

  @@index([clientId, status])
  @@index([subscriptionId, dueDate])
}

/// Mensalidade recorrente de um cliente — gera cobranças (Invoice) por período
model Subscription {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  description   String   @default("Mensalidade")
  amount        Decimal  @db.Decimal(12, 2)
  /// MENSAL | TRIMESTRAL | ANUAL
  frequency     String   @default("MENSAL")
  startDate     DateTime @default(now())
  /// Dia do mês em que a cobrança vence
  dueDay        Int      @default(5)
  /// ATIVA | PAUSADA | CANCELADA
  status        String   @default("ATIVA")
  paymentMethod PaymentMethod?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  invoices      Invoice[]

  @@index([clientId, status])
}

model Expense {
  id          String   @id @default(cuid())
  description String // nome do custo
  category    String // softwares | hospedagem | funcionarios | comissoes | marketing | trafego_pago | ...
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime // data de vencimento/competência
  recurring   Boolean  @default(false)
  frequency   String   @default("unica") // mensal | anual | unica
  status      String   @default("ATIVO") // ATIVO | PAGO | CANCELADO
  notes       String?
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

/// Comissão de colaborador por cliente (percentual sobre a receita ou valor fixo mensal)
model StaffCommission {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // PERCENTUAL | FIXO
  value     Decimal  @db.Decimal(12, 2)
  note      String?
  createdAt DateTime @default(now())

  @@unique([clientId, userId])
}

/// Treinamentos disponibilizados no portal (gerenciados pelo admin, sem alterar código)
model Training {
  id           String   @id @default(cuid())
  title        String
  description  String?
  category     String
  videoUrl     String // YouTube/Vimeo — convertido para embed na exibição
  thumbnailUrl String?
  duration     String? // ex.: "12 min"
  publishedAt  DateTime @default(now())
  active       Boolean  @default(true)
}

// ─────────────────────────────── Documentos ───────────────────────────────

enum DocumentType {
  CONTRATO
  BRIEFING
  CRIATIVO
  RELATORIO
  APRESENTACAO
  NOTA_FISCAL
  PLANEJAMENTO
  VIDEO
  IMAGEM
  OUTRO
}

// ─────────────────────────────── Calendário de postagens ───────────────────────────────

model ContentPost {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date            DateTime
  title           String
  format          String?  // Reels | Carrossel | Story | Feed | Live | Vídeo | Outro
  script          String?  // roteiro da postagem
  expectedMetrics String?  // métricas esperadas (alcance, engajamento, leads…)
  status          String   @default("PLANEJADO") // PLANEJADO | APROVADO | PUBLICADO
  createdAt       DateTime @default(now())

  @@index([clientId, date])
}

/// Planos/pacotes comerciais da FortGrow (personalizáveis pelo admin)
model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  price        Decimal  @default(0) @db.Decimal(12, 2)
  description  String?
  deliverables Json     @default("[]") // lista de entregas do pacote
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Document {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  type      DocumentType @default(OUTRO)
  url       String
  sizeKb    Int          @default(0)
  uploadedBy String?
  createdAt DateTime     @default(now())
}

// ─────────────────────────────── Central de Chamados ───────────────────────────────

enum TicketStatus {
  ABERTO
  EM_ATENDIMENTO
  AGUARDANDO_CLIENTE
  RESOLVIDO
  FECHADO
}

model Ticket {
  id        String        @id @default(cuid())
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subject   String
  priority  Priority      @default(MEDIA)
  status    TicketStatus  @default(ABERTO)
  messages  TicketMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model TicketMessage {
  id            String   @id @default(cuid())
  ticketId      String
  ticket        Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId      String?
  author        User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content       String
  attachmentUrl String?
  createdAt     DateTime @default(now())
}

// ─────────────────────────────── Notificações, Automações & Logs ───────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model Automation {
  id        String   @id @default(cuid())
  name      String
  trigger   String // vencimento_fatura | contrato_renovacao | tarefa_atrasada | novo_lead | ...
  channel   String // email | whatsapp | notificacao
  template  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

/// Evento da Agenda da empresa (reuniões, captações, alinhamentos, follow-ups)
model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  /// REUNIAO_CLIENTE | CAPTACAO | ALINHAMENTO | FOLLOW_UP
  type        String   @default("REUNIAO_CLIENTE")
  /// CONFIRMADO | PENDENTE | CANCELADO
  status      String   @default("CONFIRMADO")
  start       DateTime
  end         DateTime
  /// Evento privado: visível só para o criador e participantes (e admins)
  private     Boolean  @default(false)
  /// Cor personalizada do evento (azul|verde|roxo|laranja|rosa|vermelho|ciano|amarelo); null = cor do tipo
  color       String?
  /// Recorrência: NENHUMA | SEMANAL | MENSAL | ANUAL
  recurrence  String   @default("NENHUMA")
  /// Última data em que a recorrência vale (null = sem fim)
  recurrenceUntil DateTime?
  /// IDs dos colaboradores participantes
  attendeeIds Json     @default("[]")
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?    @relation("eventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  /// Vinculação futura com o Google Calendar (sincronização bidirecional)
  googleEventId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([start])
  @@index([clientId, start])
}

/// Campanha sincronizada de uma plataforma de anúncios (Meta hoje; Google/TikTok no futuro)
model AdCampaign {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider    String   @default("META") // META | GOOGLE | TIKTOK
  accountId   String // act_XXXX
  externalId  String
  name        String
  status      String?
  objective   String?
  dailyBudget Decimal  @default(0) @db.Decimal(12, 2)
  syncedAt    DateTime @updatedAt
  adSets      AdSet[]
  insights    AdInsight[]

  @@unique([provider, externalId])
  @@index([clientId, provider])
}

/// Conjunto de anúncios de uma campanha sincronizada
model AdSet {
  id         String     @id @default(cuid())
  campaignId String
  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  externalId String     @unique
  name       String
  status     String?
  budget     Decimal    @default(0) @db.Decimal(12, 2)
  /// Resumo do público (idades, gêneros, geolocalização)
  audience   String?
  ads        Ad[]
}

/// Anúncio individual (criativo) de um conjunto
model Ad {
  id            String  @id @default(cuid())
  adSetId       String
  adSet         AdSet   @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  externalId    String  @unique
  name          String
  status        String?
  creativeTitle String?
  creativeBody  String?
  thumbnailUrl  String?
}

/// Métricas diárias por campanha sincronizada
model AdInsight {
  id          String     @id @default(cuid())
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  date        DateTime
  impressions Int        @default(0)
  reach       Int        @default(0)
  clicks      Int        @default(0)
  linkClicks  Int        @default(0)
  leads       Int        @default(0)
  conversions Int        @default(0)
  spend       Decimal    @default(0) @db.Decimal(12, 2)
  frequency   Float      @default(0)

  @@unique([campaignId, date])
  @@index([date])
}

/// Registro de execuções de sincronização (visível em Integrações)
model SyncLog {
  id         String    @id @default(cuid())
  provider   String
  scope      String    @default("all") // "all" ou clientId
  status     String // OK | ERRO | PARCIAL
  message    String?
  items      Int       @default(0)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([provider, startedAt])
}

/// Configurações gerais do sistema (chave → valor)
/// Dashboard de performance por cliente: lançamentos manuais (estilo planilha).
/// KPIs (CAC, CPL, ticket médio, valor por lead) são derivados — nunca armazenados.
model PerformanceEntry {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date       DateTime
  investment Decimal  @default(0) @db.Decimal(12, 2)
  leads      Int      @default(0)
  sales      Int      @default(0)
  /// Receita bruta (valor total vendido) do dia
  revenue    Decimal  @default(0) @db.Decimal(12, 2)
  /// Overrides por linha da base de cálculo; null = usa o padrão do cliente
  convPercent       Decimal? @db.Decimal(6, 3)
  commissionPercent Decimal? @db.Decimal(6, 3)
  /// Origem dos leads: INDICACAO | TRAFEGO_PAGO | ORGANICO | SOCIAL | OUTRO
  source     String   @default("OUTRO")

  salesDetails PerformanceSale[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([clientId, date])
}

/// Detalhe de uma venda dentro de um lançamento de Performance: quem vendeu,
/// valor, comprador e observações. Quando um lançamento tem detalhes, os
/// campos Vendas e Receita bruta da linha são sincronizados a partir deles.
model PerformanceSale {
  id         String           @id @default(cuid())
  entryId    String
  entry      PerformanceEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  sellerName String
  buyer      String?
  amount     Decimal          @default(0) @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([entryId])
}

/// Painel de Instagram do dashboard de Performance: lançamentos manuais
/// diários; taxa de engajamento e crescimento são derivados, nunca armazenados.
model InstagramEntry {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date            DateTime
  views           Int      @default(0)
  likes           Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  saves           Int      @default(0)
  followers       Int      @default(0)
  reach           Int      @default(0)
  /// % do alcance vindo de não seguidores (expansão de público)
  nonFollowersPct Decimal  @default(0) @db.Decimal(6, 3)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId, date])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Integration {
  id        String   @id @default(cuid())
  provider  String   @unique // google_ads | meta_ads | ga4 | search_console | instagram | stripe | asaas | whatsapp | ...
  connected Boolean  @default(false)
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Templates de permissão nomeados (ex.: "Vendedor Jr", "Gestor de contas")
model PermissionTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  matrix    Json     @default("{}")
  createdAt DateTime @default(now())
}
