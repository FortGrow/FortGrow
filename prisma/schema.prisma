// FortGrow CRM — Schema do banco de dados (PostgreSQL)
// Multi-tenant: todos os dados de cliente são isolados por clientId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Usuários & RBAC ───────────────────────────────

enum Role {
  ADMIN
  FINANCEIRO
  COMERCIAL
  GESTOR
  SOCIAL_MEDIA
  DESIGNER
  TRAFEGO_PAGO
  CONSULTOR
  CLIENTE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CONSULTOR)
  avatarUrl    String?
  phone        String?
  active       Boolean  @default(true)
  twoFactor    Boolean  @default(false)
  // Módulos liberados para colaboradores (chaves de módulo, ex.: "crm", "financeiro")
  permissions  String[] @default([])
  // Usuários CLIENTE pertencem a um cliente e só enxergam os dados dele
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  accountFor    Client[]       @relation("accountManager")
  consultantFor Client[]       @relation("consultant")
  leads         Lead[]
  tasks         Task[]
  ticketMsgs    TicketMessage[]
  notifications Notification[]
  logs          ActivityLog[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime
}

// ─────────────────────────────── Clientes (tenants) ───────────────────────────────

enum ClientStatus {
  ATIVO
  PAUSADO
  INATIVO
  ONBOARDING
}

model Client {
  id             String       @id @default(cuid())
  companyName    String
  tradeName      String?
  logoUrl        String?
  cnpj           String?
  segment        String?
  city           String?
  state          String?
  website        String?
  instagram      String?
  email          String?
  phone          String?
  status         ClientStatus @default(ATIVO)
  plan           String?
  monthlyValue   Decimal      @default(0) @db.Decimal(12, 2)
  contractStart  DateTime?
  contractMonths Int?
  projectStatus  String?      @default("Em andamento")

  accountManagerId String?
  accountManager   User?   @relation("accountManager", fields: [accountManagerId], references: [id], onDelete: SetNull)
  consultantId     String?
  consultant       User?   @relation("consultant", fields: [consultantId], references: [id], onDelete: SetNull)

  users      User[]
  services   ClientService[]
  contracts  Contract[]
  projects   Project[]
  campaigns  Campaign[]
  invoices   Invoice[]
  expenses   Expense[]
  documents  Document[]
  tickets    Ticket[]
  metrics    MetricSnapshot[]
  goals      Goal[]
  leads      Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────── CRM Comercial ───────────────────────────────

enum LeadStage {
  LEAD
  CONTATO
  DIAGNOSTICO
  REUNIAO
  PROPOSTA
  NEGOCIACAO
  FECHADO
  PERDIDO
}

model Lead {
  id             String    @id @default(cuid())
  companyName    String
  contactName    String?
  email          String?
  phone          String?
  whatsapp       String?
  instagram      String?
  facebook       String?
  linkedin       String?
  website        String?
  source         String?
  segment        String?
  city           String?
  state          String?
  potential      String?   @default("Médio") // Baixo | Médio | Alto
  estimatedValue Decimal   @default(0) @db.Decimal(12, 2)
  notes          String?
  stage          LeadStage @default(LEAD)
  position       Int       @default(0)
  ownerId        String?
  owner          User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  // Quando fechado, pode virar cliente
  clientId       String?
  client         Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  activities LeadActivity[]
  proposals  Proposal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String   @default("nota") // nota | ligacao | email | reuniao | whatsapp | mudanca_etapa
  content   String
  author    String?
  createdAt DateTime @default(now())
}

enum ProposalStatus {
  ABERTA
  ENVIADA
  ACEITA
  RECUSADA
}

model Proposal {
  id        String         @id @default(cuid())
  title     String
  leadId    String
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  value     Decimal        @default(0) @db.Decimal(12, 2)
  status    ProposalStatus @default(ABERTA)
  validUntil DateTime?
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// ─────────────────────────────── Serviços & Contratos ───────────────────────────────

model Service {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  basePrice   Decimal         @default(0) @db.Decimal(12, 2)
  active      Boolean         @default(true)
  clients     ClientService[]
  createdAt   DateTime        @default(now())
}

enum ServiceStatus {
  ATIVO
  PAUSADO
  CONCLUIDO
  ATRASADO
}

model ClientService {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status      ServiceStatus @default(ATIVO)
  startDate   DateTime?
  deadline    DateTime?
  responsible String?
  checklist   Json          @default("[]") // [{label, done}]
  createdAt   DateTime      @default(now())
}

enum ContractStatus {
  ATIVO
  ENCERRADO
  RENOVACAO
  CANCELADO
}

model Contract {
  id           String         @id @default(cuid())
  clientId     String
  client       Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title        String
  value        Decimal        @default(0) @db.Decimal(12, 2)
  startDate    DateTime
  endDate      DateTime?
  status       ContractStatus @default(ATIVO)
  fileUrl      String?
  autoRenew    Boolean        @default(false)
  createdAt    DateTime       @default(now())
}

// ─────────────────────────────── Projetos & Tarefas ───────────────────────────────

enum ProjectStatus {
  BACKLOG
  EM_ANDAMENTO
  REVISAO
  CONCLUIDO
  ATRASADO
}

enum Priority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model Project {
  id        String        @id @default(cuid())
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  status    ProjectStatus @default(BACKLOG)
  priority  Priority      @default(MEDIA)
  startDate DateTime?
  deadline  DateTime?
  progress  Int           @default(0)
  notes     String?
  tasks     Task[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum TaskStatus {
  A_FAZER
  EM_ANDAMENTO
  EM_REVISAO
  CONCLUIDA
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(A_FAZER)
  priority    Priority   @default(MEDIA)
  dueDate     DateTime?
  timeSpentMin Int       @default(0)
  checklist   Json       @default("[]")
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?      @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    Json       @default("[]") // [{author, content, at}]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ─────────────────────────────── Campanhas & Métricas ───────────────────────────────

enum Channel {
  GOOGLE_ADS
  META_ADS
  INSTAGRAM
  SEO
  LINKEDIN
  TIKTOK
  EMAIL
  OUTRO
}

model Campaign {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  channel    Channel
  active     Boolean  @default(true)
  budget     Decimal  @default(0) @db.Decimal(12, 2)
  objective  String?
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime @default(now())
}

/// Snapshot diário de métricas por canal — alimentado pelas integrações
/// (Google Ads, Meta Ads, Instagram, Search Console) ou lançado manualmente.
model MetricSnapshot {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channel     Channel
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  reach       Int      @default(0)
  engagement  Int      @default(0)
  followers   Int      @default(0)
  leads       Int      @default(0)
  conversions Int      @default(0)
  spend       Decimal  @default(0) @db.Decimal(12, 2)
  revenue     Decimal  @default(0) @db.Decimal(12, 2)
  // SEO
  organicTraffic Int   @default(0)
  avgPosition    Float @default(0)
  backlinks      Int   @default(0)
  authority      Int   @default(0)

  @@unique([clientId, channel, date])
  @@index([clientId, date])
}

model Goal {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  metric    String // leads | receita | conversoes | seguidores
  period    String // mensal | anual
  target    Decimal  @default(0) @db.Decimal(12, 2)
  year      Int
  month     Int?
}

// ─────────────────────────────── Financeiro ───────────────────────────────

enum InvoiceStatus {
  EM_ABERTO
  PAGO
  ATRASADO
  CANCELADO
}

enum PaymentMethod {
  PIX
  BOLETO
  CARTAO
  TRANSFERENCIA
}

model Invoice {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal       @db.Decimal(12, 2)
  dueDate     DateTime
  paidAt      DateTime?
  status      InvoiceStatus @default(EM_ABERTO)
  method      PaymentMethod?
  nfeUrl      String?
  createdAt   DateTime      @default(now())

  @@index([clientId, status])
}

model Expense {
  id          String   @id @default(cuid())
  description String
  category    String // midia | ferramentas | pessoal | impostos | outros
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

// ─────────────────────────────── Documentos ───────────────────────────────

enum DocumentType {
  CONTRATO
  BRIEFING
  CRIATIVO
  RELATORIO
  APRESENTACAO
  NOTA_FISCAL
  VIDEO
  IMAGEM
  OUTRO
}

model Document {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  type      DocumentType @default(OUTRO)
  url       String
  sizeKb    Int          @default(0)
  uploadedBy String?
  createdAt DateTime     @default(now())
}

// ─────────────────────────────── Central de Chamados ───────────────────────────────

enum TicketStatus {
  ABERTO
  EM_ATENDIMENTO
  AGUARDANDO_CLIENTE
  RESOLVIDO
  FECHADO
}

model Ticket {
  id        String        @id @default(cuid())
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subject   String
  priority  Priority      @default(MEDIA)
  status    TicketStatus  @default(ABERTO)
  messages  TicketMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model TicketMessage {
  id            String   @id @default(cuid())
  ticketId      String
  ticket        Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId      String?
  author        User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content       String
  attachmentUrl String?
  createdAt     DateTime @default(now())
}

// ─────────────────────────────── Notificações, Automações & Logs ───────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model Automation {
  id        String   @id @default(cuid())
  name      String
  trigger   String // vencimento_fatura | contrato_renovacao | tarefa_atrasada | novo_lead | ...
  channel   String // email | whatsapp | notificacao
  template  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Integration {
  id        String   @id @default(cuid())
  provider  String   @unique // google_ads | meta_ads | ga4 | search_console | instagram | stripe | asaas | whatsapp | ...
  connected Boolean  @default(false)
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
