# Banco de dados PostgreSQL (Supabase ou local)
# Supabase: Settings > Database > Connection string (URI)
DATABASE_URL="postgresql://fortgrow:fortgrow@localhost:5432/fortgrow?schema=public"

# Segredo usado para assinar os tokens JWT de sessão (troque em produção!)
AUTH_SECRET="troque-este-segredo-em-producao-por-um-valor-aleatorio-longo"

# URL pública da aplicação
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Integrações (opcionais — os dashboards usam dados sincronizados no banco)
GOOGLE_ADS_DEVELOPER_TOKEN=""
META_ADS_ACCESS_TOKEN=""
OPENAI_API_KEY=""
WHATSAPP_BUSINESS_TOKEN=""
STRIPE_SECRET_KEY=""
ASAAS_API_KEY=""
